# Loaded only by `npm run dev:emulators` (vite --mode emulators). This mode file takes
# priority over .env.local, so it reliably points the app at the local Firebase Emulator
# Suite even when .env.local sets VITE_USE_EMULATORS=false for your real project.
# Your real Firebase config still comes from .env.local (the emulators ignore it anyway).
VITE_USE_EMULATORS=true
