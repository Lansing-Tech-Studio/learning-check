# Firebase web config — copy to `.env.local` and fill in from your Firebase project's
# web app settings (Project settings → General → Your apps → SDK setup & configuration).
# These values are NOT secret: they ship in the client bundle. Security comes from
# firestore.rules, not from hiding these.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Set to "true" (via `npm run dev:emulators`) to point the app at the local Firebase
# Emulator Suite instead of the live project.
# VITE_USE_EMULATORS=true
